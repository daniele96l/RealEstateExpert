# Playwright scrapers (Idealista, Immobiliare, Casa.it, Subito, market pages)
# After npm install: npx playwright install chromium
# Optional headed mode: PORTAL_BROWSER_HEADED=1 or IDEALISTA_BROWSER_HEADED=1

# Immobiliare listing import uses Playwright (no external API).
# Optional: IMMOBILIARE_BROWSER_PROFILE=/path/to/profile  (persistent cookies)
# Optional: IMMOBILIARE_BROWSER_HEADED=1  (show browser during scrape)
# Step 1 — solve captcha once:  npm run immobiliare:captcha
# Step 2 — scrape city:         npm run scrape:immobiliare:city -- "reggio calabria"

# Vercel Cron — occupancy snapshots (daily 06:00/06:20/06:40 UTC, one per portal).
# Vercel injects CRON_SECRET automatically.
# Local test (all portals): CRON_SECRET=devsecret curl -H "Authorization: Bearer devsecret" http://localhost:3000/api/cron/occupancy
# Local test (one portal):  CRON_SECRET=devsecret curl -H "Authorization: Bearer devsecret" "http://localhost:3000/api/cron/occupancy?portal=idealista_scraper"
CRON_SECRET=
