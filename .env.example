# ScrapingBee (scraping HTML Idealista)
SCRAPINGBEE_API_KEY=your_scrapingbee_api_key_here

# RapidAPI — same key for both APIs below
RAPIDAPI_KEY=your_rapidapi_key_here
# Idealista17 — https://rapidapi.com/happyendpoint/api/idealista17
# Immobiliare.it Scraper — https://rapidapi.com (search "immobiliare-it-scraper") for batch city import

# RealtyAPI — https://www.realtyapi.io/dashboard (Immobiliare.it)
REALTYAPI_KEY=your_realtyapi_key_here

# Provider predefinito: realtyapi | rapidapi | scrapingbee | direct
LISTINGS_PROVIDER=realtyapi

# Disabilita RapidAPI (es. quota mensile esaurita — 429)
# RAPIDAPI_DISABLED=1

# Idealista direct scraper (Playwright fallback, free)
# IDEALISTA_BROWSER_HEADED=1

# Optional — Immobiliare Insights API (official market data)
IMMOBILIARE_INSIGHTS_CLIENT_ID=
IMMOBILIARE_INSIGHTS_CLIENT_SECRET=
IMMOBILIARE_INSIGHTS_USERNAME=
IMMOBILIARE_INSIGHTS_PASSWORD=
# IMMOBILIARE_INSIGHTS_BASE_URL=https://ws-osservatorio.realitycs.it

# Market data provider: auto | scrapingbee | insights
MARKET_PROVIDER=auto

# Immobiliare listing import uses Playwright (no external API).
# After npm install, run: npx playwright install chromium
# Optional: IMMOBILIARE_BROWSER_PROFILE=/path/to/profile  (persistent cookies)
# Optional: IMMOBILIARE_BROWSER_HEADED=1  (show browser during scrape)
# Step 1 — solve captcha once:  npm run immobiliare:captcha
# Step 2 — scrape city:         npm run scrape:immobiliare:city -- "reggio calabria"
# Test providers:               npm run listings:test-providers -- "Reggio Calabria" --rent

# Vercel Cron — occupancy snapshots (daily 06:00/06:20/06:40 UTC, one per portal).
# Vercel injects CRON_SECRET automatically.
# Local test (all portals): CRON_SECRET=devsecret curl -H "Authorization: Bearer devsecret" http://localhost:3000/api/cron/occupancy
# Local test (one portal):  CRON_SECRET=devsecret curl -H "Authorization: Bearer devsecret" "http://localhost:3000/api/cron/occupancy?portal=idealista"
CRON_SECRET=
