# Headless scrapers (Playwright / patchright). Install browsers once:
#   npx playwright install chromium

# Optional residential proxy (last resort when DataDome blocks your IP)
# SCRAPER_PROXY_SERVER=http://user:pass@host:port

# Optional persistent browser profiles (cookies can reduce captcha rate)
# IDEALISTA_BROWSER_PROFILE=~/.idealista-browser
# IMMOBILIARE_BROWSER_PROFILE=~/.immobiliare-browser

# Optional: force Chrome channel on non-macOS (default: chrome on macOS)
# SCRAPER_BROWSER_CHANNEL=chrome

# Vercel Cron — occupancy snapshots (daily 06:00/06:20/06:40 UTC, one per portal).
# Vercel injects CRON_SECRET automatically.
# Local test (all portals): CRON_SECRET=devsecret curl -H "Authorization: Bearer devsecret" http://localhost:3000/api/cron/occupancy
# Local test (one portal):  CRON_SECRET=devsecret curl -H "Authorization: Bearer devsecret" "http://localhost:3000/api/cron/occupancy?portal=idealista_scraper"
CRON_SECRET=
