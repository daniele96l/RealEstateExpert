# ScrapingBee (scraping HTML Idealista)
SCRAPINGBEE_API_KEY=your_scrapingbee_api_key_here

# RapidAPI Idealista17 — https://rapidapi.com/happyendpoint/api/idealista17
RAPIDAPI_KEY=your_rapidapi_key_here

# Provider predefinito: rapidapi | scrapingbee
LISTINGS_PROVIDER=rapidapi

# Optional — Immobiliare Insights API (official market data)
IMMOBILIARE_INSIGHTS_CLIENT_ID=
IMMOBILIARE_INSIGHTS_CLIENT_SECRET=
IMMOBILIARE_INSIGHTS_USERNAME=
IMMOBILIARE_INSIGHTS_PASSWORD=
# IMMOBILIARE_INSIGHTS_BASE_URL=https://ws-osservatorio.realitycs.it

# Market data provider: auto | scrapingbee | insights
MARKET_PROVIDER=auto
