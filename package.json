{
  "name": "realestate-expert",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "node scripts/dev.mjs",
    "dev:stop": "node scripts/dev-stop.mjs",
    "dev:clean": "npm run clean && node scripts/dev.mjs --force",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "scrape:immobiliare": "tsx scripts/scrape-immobiliare.ts",
    "scrape:immobiliare:city": "tsx scripts/scrape-immobiliare-city.ts",
    "scrape:immobiliare:city:py": "python3 scripts/scrape_immobiliare_city.py",
    "scrape:idealista:city": "tsx scripts/scrape-idealista-city.ts",
    "occupancy:poll": "tsx scripts/poll-occupancy.ts --city=reggio_calabria",
    "occupancy:poll:brno": "tsx scripts/poll-occupancy.ts --city=brno",
    "occupancy:seed:brno": "tsx scripts/seed-occupancy-brno.ts",
    "data:sync-immobiliare": "tsx scripts/sync-prod-immobiliare.ts",
    "data:sync-brno": "tsx scripts/sync-prod-brno.ts",
    "data:sync-occupancy": "npm run data:sync-immobiliare && npm run data:sync-brno",
    "build:reggio-zones": "tsx scripts/build-reggio-zone-polygons.ts",
    "scrape:test-portals": "tsx scripts/test-portal-scrapers.ts",
    "scrape:test-all": "tsx scripts/test-all-scrapers.ts",
    "test:casa-scraper": "tsx lib/server/casa-search.test.ts",
    "test:subito-scraper": "tsx lib/server/subito-search.test.ts",
    "test:occupancy-rebasing": "tsx lib/occupancy/rebasing.test.ts"
  },
  "dependencies": {
    "@turf/bbox": "^7.3.5",
    "@turf/intersect": "^7.3.5",
    "@turf/voronoi": "^7.3.5",
    "apify-client": "^2.23.4",
    "cheerio": "^1.2.0",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "lucide-react": "^0.469.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@turf/area": "^7.3.5",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/simplify": "^7.3.5",
    "@turf/union": "^7.3.5",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet-draw": "^1.0.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "patchright": "^1.61.1",
    "playwright": "^1.51.0",
    "postcss": "^8.4.49",
    "shapefile": "^0.6.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
